# Timetable Generator - Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================================================
# Server Configuration
# ============================================================================
SERVER_HOST=0.0.0.0
SERVER_PORT=8010
LOG_LEVEL=INFO

# ============================================================================
# Database (Supabase)
# ============================================================================
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_KEY=eyJhbGci...your-anon-key
SUPABASE_JWT_SECRET=your-jwt-secret

# ============================================================================
# Redis (Upstash or self-hosted)
# ============================================================================
# For Upstash Redis:
REDIS_URL=rediss://default:xxxxx@xxxxx.upstash.io:6379
UPSTASH_REDIS_TOKEN=optional-if-using-upstash

# For local Redis:
# REDIS_URL=redis://localhost:6379

# ============================================================================
# Storage (Cloudflare R2)
# ============================================================================
R2_BUCKET=timetable-results
R2_ENDPOINT_URL=https://xxxxx.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_PUBLIC_URL=https://pub-xxxxx.r2.dev
R2_PRESIGNED_URL_EXPIRATION_SEC=3600

# ============================================================================
# Observability (Sentry)
# ============================================================================
SENTRY_DSN=https://xxxxx@o000000.ingest.sentry.io/0000000
SENTRY_ENABLED=true
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# ============================================================================
# Solver Configuration
# ============================================================================
DEFAULT_SOLVE_TIME_SEC=25
MAX_SOLVE_TIME_SEC=120
CP_SAT_SEARCH_WORKERS=4
SOLVER_NUM_WORKERS=4

# ============================================================================
# Concurrency Limits
# ============================================================================
# Global limit: max concurrent solves across ALL tenants
MAX_GLOBAL_ACTIVE_SOLVES=6

# Per-tenant limit: max concurrent solves per single tenant
MAX_PER_TENANT_ACTIVE=1

# Worker configuration
WORKER_POLL_INTERVAL_SEC=1.0
WORKER_SEMAPHORE_TTL_SEC=300
WORKER_ID=worker-1

# ============================================================================
# Job Configuration
# ============================================================================
MAX_CONCURRENT_JOBS=10
JOB_RETENTION_HOURS=48

# ============================================================================
# Parser Configuration
# ============================================================================
# Files smaller than this will be parsed synchronously
PARSE_SYNC_MAX_SIZE=1048576

# ============================================================================
# CORS Configuration (for frontend)
# ============================================================================
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com
CORS_ALLOW_CREDENTIALS=true

# ============================================================================
# Development/Testing Overrides
# ============================================================================
# Uncomment for local development with minio instead of R2
# R2_ENDPOINT_URL=http://localhost:9000
# R2_ACCESS_KEY_ID=minioadmin
# R2_SECRET_ACCESS_KEY=minioadmin
# R2_BUCKET=timetable-dev

# Uncomment for local Redis
# REDIS_URL=redis://localhost:6379

# Uncomment for local Postgres (if not using Supabase)
# SUPABASE_URL=postgresql://postgres:postgres@localhost:5432/timetable
