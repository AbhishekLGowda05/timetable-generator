{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "solver_output.schema.json",
  "title": "Solver Output",
  "description": "Generated timetable output from the solver",
  "type": "object",
  "required": ["status", "timetable"],
  "properties": {
    "status": {
      "type": "string",
      "description": "Solver result status",
      "enum": ["OPTIMAL", "FEASIBLE", "INFEASIBLE", "TIMEOUT", "ERROR"]
    },
    "timetable": {
      "type": "object",
      "description": "Generated timetable by section",
      "additionalProperties": {
        "type": "object",
        "description": "Timetable for a section, keyed by day",
        "additionalProperties": {
          "type": "array",
          "description": "Periods for a day",
          "items": {
            "type": "object",
            "required": ["period", "subject_id", "teacher_id"],
            "properties": {
              "period": {
                "type": "integer",
                "description": "Period number (0 = prayer/assembly)",
                "minimum": 0
              },
              "subject_id": {
                "type": "string",
                "description": "Assigned subject ID"
              },
              "subject_name": {
                "type": "string",
                "description": "Display name of subject"
              },
              "teacher_id": {
                "type": "string",
                "description": "Assigned teacher ID"
              },
              "teacher_name": {
                "type": "string",
                "description": "Display name of teacher"
              },
              "resource_id": {
                "type": "string",
                "description": "Assigned resource ID if applicable"
              },
              "is_block_start": {
                "type": "boolean",
                "description": "Whether this is the start of a block period",
                "default": false
              },
              "is_block_continuation": {
                "type": "boolean",
                "description": "Whether this is a continuation of a block period",
                "default": false
              },
              "start_time": {
                "type": "string",
                "description": "Period start time in HH:MM format"
              },
              "end_time": {
                "type": "string",
                "description": "Period end time in HH:MM format"
              }
            },
            "additionalProperties": false
          }
        }
      }
    },
    "teacher_schedules": {
      "type": "object",
      "description": "Generated schedule view by teacher",
      "additionalProperties": {
        "type": "object",
        "description": "Schedule for a teacher, keyed by day",
        "additionalProperties": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "period": {
                "type": "integer"
              },
              "section_id": {
                "type": "string"
              },
              "subject_id": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "meta": {
      "type": "object",
      "description": "Solver metadata and statistics",
      "properties": {
        "solve_time_seconds": {
          "type": "number",
          "description": "Time taken to solve in seconds"
        },
        "variables_count": {
          "type": "integer",
          "description": "Number of decision variables"
        },
        "constraints_count": {
          "type": "integer",
          "description": "Number of constraints"
        },
        "objective_value": {
          "type": "number",
          "description": "Final objective function value"
        },
        "soft_violations": {
          "type": "object",
          "description": "Count of soft constraint violations by type",
          "additionalProperties": {
            "type": "integer"
          }
        },
        "solver_status_code": {
          "type": "integer",
          "description": "Raw OR-Tools status code"
        }
      },
      "additionalProperties": false
    },
    "diagnostics": {
      "type": "array",
      "description": "Diagnostic messages if solver failed",
      "items": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": ["error", "warning", "suggestion"]
          },
          "category": {
            "type": "string",
            "description": "Category of issue (e.g., 'teacher_overload', 'resource_conflict')"
          },
          "message": {
            "type": "string",
            "description": "Human-readable description"
          },
          "affected_entities": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of affected entity IDs"
          },
          "suggestion": {
            "type": "string",
            "description": "Recommended action to resolve"
          }
        },
        "additionalProperties": false
      }
    },
    "warnings": {
      "type": "array",
      "description": "Non-critical warnings",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}