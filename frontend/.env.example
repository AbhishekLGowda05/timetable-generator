# Environment Variables
# Copy this file to .env and update the values

# Backend API URL (timetable solver service)
VITE_API_URL=http://localhost:8010

# Optional: ADK/Agent API URL for ERP integration
VITE_ADK_API_URL=http://localhost:8004

# Optional: Enable mock API mode (for frontend development without backend)
VITE_USE_MOCK_API=false

# Optional: Maximum file upload size in MB
VITE_MAX_UPLOAD_SIZE_MB=10

# Optional: Enable debug mode
VITE_DEBUG=false

# Optional: Sentry DSN for error tracking
VITE_SENTRY_DSN=

# Optional: Application version (auto-set by build pipeline)
VITE_APP_VERSION=1.0.0
